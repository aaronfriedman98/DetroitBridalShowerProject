<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>With Gratitude &mdash; Detroit Bridal Shower</title>
<link rel="icon" href="../assets/images/bridalshowerpic.jpg">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root { --ivory:#f4f1ea; --sage:#494e46; --sage-dark:#383c36; --gold:#b3925a; --gold-soft:#f3ead9; --ink:#2e2e29; --soft:#6d6d64; --line:#e7e2d8;
    --serif:'Cormorant Garamond',Georgia,serif; --sans:'Jost','Segoe UI',sans-serif; }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--ivory); font-family:var(--sans); color:var(--ink); }
  a { text-decoration:none; }
  .n-nav { position:sticky; top:0; z-index:50; background:rgba(244,241,234,.92); backdrop-filter:blur(10px); border-bottom:1px solid var(--line); }
  .n-nav-in { max-width:1180px; margin:0 auto; padding:14px 22px; display:flex; align-items:center; gap:26px; }
  .n-brand { display:flex; align-items:center; gap:12px; }
  .n-brand img { width:44px; height:44px; object-fit:contain; background:#fff; border-radius:50%; padding:4px; border:1px solid var(--line); }
  .n-brand span { font-family:var(--serif); font-weight:600; font-size:17px; letter-spacing:.14em; text-transform:uppercase; color:var(--sage-dark); line-height:1.2; }
  .n-links { display:flex; align-items:center; gap:26px; margin-left:auto; }
  .n-links a { font-size:13.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--sage); }
  .n-links a:hover { color:var(--gold); }
  .n-cta { background:var(--gold); color:#fff !important; border-radius:999px; padding:11px 24px; }
  @media (max-width:820px){ .n-links a:not(.n-cta){ display:none; } }
  .hero { text-align:center; padding:56px 16px 8px; }
  .hero img { width:104px; margin:0 auto 14px; display:block; }
  .kicker { font-size:12px; letter-spacing:5px; text-transform:uppercase; color:var(--gold); font-weight:500; }
  .hero h1 { font-family:var(--serif); font-style:italic; font-weight:500; font-size:clamp(36px,5vw,46px); color:var(--gold); margin:10px 0 8px; }
  .hero p { font-family:var(--serif); font-size:19px; color:var(--soft); line-height:1.6; max-width:520px; margin:0 auto; }
  .wrap { max-width:620px; margin:24px auto 70px; padding:0 16px; }

  .searchbox { position:relative; }
  .searchbox svg { position:absolute; left:18px; top:50%; transform:translateY(-50%); width:17px; height:17px; color:var(--soft); pointer-events:none; }
  .searchbox input { width:100%; padding:16px 20px 16px 48px; border:1px solid var(--line); border-radius:999px; font-size:17px;
    font-family:var(--serif); color:var(--sage-dark); background:#fff; outline:none; box-shadow:0 8px 26px -18px rgba(56,60,54,.35); }
  .searchbox input:focus { border-color:var(--gold); box-shadow:0 0 0 3px rgba(179,146,90,.14); }
  .results { background:#fff; border:1px solid var(--line); border-radius:16px; margin-top:10px; overflow:hidden; display:none; box-shadow:0 14px 34px -20px rgba(56,60,54,.35); }
  .results.show { display:block; }
  .result { display:block; width:100%; text-align:left; background:none; border:none; cursor:pointer;
    padding:13px 20px; font-family:var(--serif); font-size:18px; color:var(--sage); border-bottom:1px solid #f0ece3; }
  .result:last-child { border-bottom:none; }
  .result:hover { background:#faf6ee; color:var(--gold); }
  .result small { display:block; font-family:var(--sans); font-size:11.5px; color:var(--soft); letter-spacing:.04em; }
  .noresult { padding:16px 20px; font-family:var(--sans); font-weight:300; font-size:14px; color:var(--soft); }

  .card { display:none; background:#fff; border:1px solid var(--line); border-radius:18px; padding:30px 28px; margin-top:16px;
    box-shadow:0 10px 30px -18px rgba(56,60,54,.25); text-align:center; }
  .card.show { display:block; animation:pop .2s ease; }
  @keyframes pop { from { transform:translateY(6px); opacity:0; } to { transform:none; opacity:1; } }
  .card h2 { font-family:var(--serif); font-size:26px; color:var(--sage-dark); }
  .thanks { font-size:11px; letter-spacing:3px; text-transform:uppercase; color:var(--gold); font-weight:500; margin:14px 0 4px; }
  .names { font-family:var(--serif); font-size:19px; color:var(--ink); line-height:2; }
  .names span { display:inline-block; padding:0 10px; }
  .divider { width:54px; height:1px; background:#d9c9a6; margin:14px auto; }

  .mine { margin-top:56px; text-align:center; }
  .mine .kicker { margin-bottom:6px; }
  .mine h2 { font-family:var(--serif); font-weight:600; font-size:26px; color:var(--sage-dark); margin-bottom:8px; }
  .mine .sub { font-family:var(--sans); font-weight:300; font-size:14px; color:var(--soft); line-height:1.6; max-width:440px; margin:0 auto 16px; }
  .mailrow { display:flex; border:1px solid var(--line); border-radius:999px; overflow:hidden; background:#fff; max-width:430px; margin:0 auto; }
  .mailrow:focus-within { border-color:var(--gold); box-shadow:0 0 0 3px rgba(179,146,90,.13); }
  .mailrow input { flex:1; border:none; outline:none; padding:14px 20px; font-size:15px; font-family:var(--sans); min-width:0; }
  .mailrow button { border:none; background:var(--gold); color:#fff; padding:0 24px; font-family:var(--sans); font-size:14px; letter-spacing:.04em; cursor:pointer; white-space:nowrap; }
  .mailrow button:hover { background:#a3854f; }
  .mineout { display:none; margin-top:18px; }
  .mineout.show { display:block; }
</style>
</head>
<body>
<div class="n-nav"><div class="n-nav-in">
  <a class="n-brand" href="/"><img src="../assets/images/bridalshowerpic.jpg" alt=""><span>Detroit<br>Bridal Shower</span></a>
  <div class="n-links">
    <a href="/about">About</a>
    <a href="/give">Give a Gift</a>
    <a href="/contact">Contact</a>
    <a class="n-cta" href="/#services">Add a Couple</a>
  </div>
</div></div>

<div class="hero">
  <img src="../assets/images/logo-transparent.png" alt="Detroit Bridal Shower">
  <div class="kicker">With Gratitude</div>
  <h1>Every gift builds a home</h1>
  <p>Search for a couple to see the friends and family who gave toward their bridal shower.</p>
</div>

<div class="wrap">
  <div class="searchbox">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.8-3.8"/></svg>
    <input type="search" id="q" placeholder="Search for a couple&hellip;" autocomplete="off">
  </div>
  <div class="results" id="results"></div>

  <div class="card" id="card">
    <h2 id="cNames"></h2>
    <div class="divider"></div>
    <div class="thanks">With thanks to</div>
    <div class="names" id="cList"></div>
  </div>

  <div class="mine">
    <div class="kicker">Your gifts</div>
    <h2>See who you've given to</h2>
    <div class="sub">Enter the email you used when pledging, and we'll show every couple you've contributed to.</div>
    <div class="mailrow">
      <input type="email" id="myEmail" placeholder="Your email address">
      <button type="button" onclick="lookupMine()">Show My Gifts</button>
    </div>
    <div class="card mineout" id="mineOut">
      <div class="thanks" style="margin-top:0;">You have given to</div>
      <div class="names" id="mineList"></div>
    </div>
  </div>
</div>

<script>
const DATA = <%- JSON.stringify(couples).replace(/</g, '\\u003c') %>;
const esc = s => String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const q = document.getElementById('q');
const results = document.getElementById('results');
const card = document.getElementById('card');

q.addEventListener('input', () => {
  card.classList.remove('show');
  const term = q.value.trim().toLowerCase();
  if (!term) { results.classList.remove('show'); return; }
  const hits = DATA.filter(c => c.coupleNames.toLowerCase().includes(term)).slice(0, 8);
  results.innerHTML = hits.length
    ? hits.map((c, i) => `<button class="result" onclick="pick(${DATA.indexOf(c)})">${esc(c.coupleNames)}<small>${c.contributors.length} contributor${c.contributors.length === 1 ? '' : 's'}</small></button>`).join('')
    : '<div class="noresult">No couples match "' + esc(q.value.trim()) + '" — try a first or last name.</div>';
  results.classList.add('show');
});

function pick(i) {
  const c = DATA[i];
  document.getElementById('cNames').textContent = c.coupleNames;
  document.getElementById('cList').innerHTML = c.contributors.map(n => '<span>' + esc(n) + '</span>').join(' &bull; ');
  results.classList.remove('show');
  q.value = c.coupleNames;
  card.classList.add('show');
}

async function lookupMine() {
  const em = document.getElementById('myEmail').value.trim();
  if (!/^\S+@\S+\.\S+$/.test(em)) { alert('Please enter a valid email address.'); return; }
  try {
    const res = await fetch('/contributors/lookup', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: em }) });
    const d = await res.json();
    if (!d.status) throw new Error(d.message);
    const out = document.getElementById('mineOut');
    document.getElementById('mineList').innerHTML = d.couples.length
      ? d.couples.map(n => '<span>' + esc(n) + '</span>').join(' &bull; ')
      : '<span style="font-family:var(--sans); font-size:14px; color:var(--soft); font-weight:300;">No verified gifts found for this email yet — gifts appear here once they are confirmed.</span>';
    out.classList.add('show');
  } catch (e) { alert(e.message || 'Something went wrong — please try again.'); }
}
</script>
</body>
</html>
