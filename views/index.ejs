    // addParentKallahMotherTitle: document.querySelector("#addParentKallahMotherTitle").value,
    // addParentKallahMotherName: document.querySelector("#addParentKallahMotherName").value

  };

  const request = new Request('/addEntry', {
    method: 'POST',
    body: JSON.stringify(coupleObject),
    headers: {
      'Content-Type': 'application/json'
    }
  });

  try {
    const response = await fetch(request);
    const data = await response.json();

    if (data.status === true) {
      fillInModal(data.title, data.message, true);
      document.querySelector(".formPopup").classList.remove("active");
    //   closeParentModal1();
    //   closeParentModal2();
      document.querySelector(".overlay").classList.remove("overlayActive");
      openModal();
      clearModal();
    } else {
      fillInModal(data.title, data.message, false);
      openModal();
    }
  } catch (err) {
    console.log(err);
  }

  loadingMessage.style.display = 'none';
}

        

