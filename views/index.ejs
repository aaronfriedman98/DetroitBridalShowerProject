<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detroit Bridal Shower</title>
    <link rel="icon" href="../assets/images/bridalshowerpic.jpg">
    <script src="https://kit.fontawesome.com/ec81d6615d.js" crossorigin="anonymous"></script>
    <!-- main.css + button.css power the add-couple form popup only; all visible page styling is new below -->
    <link rel="stylesheet" href="/assets/css/main.css">
    <link rel="stylesheet" href="/assets/css/button.css">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500;1,600&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
      :root { --ivory:#f4f1ea; --cream:#faf8f3; --sage:#494e46; --sage-dark:#383c36; --gold:#b3925a; --gold-soft:#f3ead9;
        --ink:#2e2e29; --soft:#6d6d64; --line:#e7e2d8; --serif:'Cormorant Garamond',Georgia,serif; --sans:'Jost','Segoe UI',sans-serif; }
      html { scroll-behavior:smooth; }
      body { margin:0 !important; padding:0 !important; background:var(--ivory) !important; background-image:none !important; font-family:var(--sans); color:var(--ink); }
      .n-page a { text-decoration:none; }
      .n-page ul { list-style:none; margin:0; padding:0; }
      .n-page h1, .n-page h2, .n-page h3, .n-page p { margin:0; }

      /* ===== nav ===== */
      .n-nav { position:sticky; top:0; z-index:50; background:rgba(244,241,234,.92); backdrop-filter:blur(10px); border-bottom:1px solid var(--line); }
      .n-nav-in { max-width:1180px; margin:0 auto; padding:14px 22px; display:flex; align-items:center; gap:26px; }
      .n-brand { display:flex; align-items:center; gap:12px; }
      .n-brand img { width:44px; height:44px; object-fit:contain; background:#fff; border-radius:50%; padding:4px; border:1px solid var(--line); }
      .n-brand span { font-family:var(--serif); font-weight:600; font-size:17px; letter-spacing:.14em; text-transform:uppercase; color:var(--sage-dark); line-height:1.2; }
      .n-links { display:flex; align-items:center; gap:26px; margin-left:auto; }
      .n-links a { font-size:13.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--sage); transition:color .15s; }
      .n-links a:hover { color:var(--gold); }
      .n-cta { background:var(--gold); color:#fff !important; border-radius:999px; padding:11px 24px; font-size:13.5px; letter-spacing:.08em; cursor:pointer; transition:background .15s; }
      .n-cta:hover { background:#a3854f; color:#fff !important; }
      .n-burger { display:none; margin-left:auto; background:none; border:none; font-size:20px; color:var(--sage); cursor:pointer; }
      .n-mobile { display:none; flex-direction:column; gap:4px; padding:10px 22px 18px; border-top:1px solid var(--line); background:var(--ivory); }
      .n-mobile a { padding:10px 4px; font-size:14px; letter-spacing:.1em; text-transform:uppercase; color:var(--sage); border-bottom:1px solid #edeae1; }
      .n-mobile.open { display:flex; }

      /* ===== hero ===== */
      .n-hero { text-align:center; padding:76px 22px 70px; position:relative; overflow:hidden; }
      .n-hero::before { content:''; position:absolute; top:-160px; left:50%; transform:translateX(-50%); width:720px; height:720px; border-radius:50%;
        background:radial-gradient(circle, rgba(179,146,90,.10) 0%, rgba(179,146,90,0) 65%); pointer-events:none; }
      .n-hero img { width:150px; height:auto; margin:0 auto 20px; display:block; position:relative; }
      .n-kicker { font-size:12px; letter-spacing:6px; text-transform:uppercase; color:var(--gold); font-weight:500; }
      .n-hero h1 { font-family:var(--serif); font-weight:500; font-size:clamp(40px,6.4vw,64px); color:var(--sage-dark); line-height:1.1; margin:18px auto 20px; max-width:760px; }
      .n-hero h1 em { font-style:italic; color:var(--gold); }
      .n-hero p { font-family:var(--serif); font-size:21px; color:var(--soft); line-height:1.6; max-width:540px; margin:0 auto 34px; }
      .n-ctas { display:flex; gap:14px; justify-content:center; flex-wrap:wrap; }
      .n-btn { display:inline-block; border-radius:999px; padding:16px 38px; font-size:15px; letter-spacing:.06em; cursor:pointer; transition:all .18s; }
      .n-btn-gold { background:var(--gold); color:#fff !important; box-shadow:0 12px 28px -12px rgba(179,146,90,.75); }
      .n-btn-gold:hover { background:#a3854f; transform:translateY(-1px); }
      .n-btn-line { border:1px solid var(--sage); color:var(--sage) !important; }
      .n-btn-line:hover { background:var(--sage); color:#fff !important; }
      .n-orn { display:flex; align-items:center; gap:14px; justify-content:center; margin-top:52px; color:#c9b98d; }
      .n-orn::before, .n-orn::after { content:''; width:70px; height:1px; background:#d9c9a6; }

      /* ===== how it works ===== */
      .n-how { background:var(--cream); border-top:1px solid var(--line); border-bottom:1px solid var(--line); padding:64px 22px 70px; }
      .n-label { text-align:center; font-size:12px; letter-spacing:5px; text-transform:uppercase; color:var(--gold); font-weight:500; }
      .n-label::after { content:''; display:block; width:54px; height:1px; background:#d9c9a6; margin:14px auto 0; }
      .n-how-grid { max-width:1000px; margin:44px auto 0; display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:34px; }
      .n-step { text-align:center; padding:0 10px; }
      .n-step .num { font-family:var(--serif); font-style:italic; font-size:44px; color:var(--gold); line-height:1; }
      .n-step h3 { font-family:var(--serif); font-weight:600; font-size:24px; color:var(--sage-dark); margin:10px 0 8px; }
      .n-step p { font-weight:300; font-size:14.5px; color:var(--soft); line-height:1.65; }

      /* ===== actions ===== */
      .n-actions { padding:70px 22px 20px; }
      .n-cards { max-width:1080px; margin:40px auto 0; display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:18px; }
      .n-card { background:#fff; border:1px solid var(--line); border-radius:20px; padding:34px 26px 30px; text-align:center;
        box-shadow:0 12px 34px -22px rgba(56,60,54,.3); transition:transform .18s, box-shadow .18s; }
      .n-card:hover { transform:translateY(-4px); box-shadow:0 22px 44px -22px rgba(56,60,54,.4); }
      .n-card i { font-size:24px; color:var(--gold); background:var(--gold-soft); width:58px; height:58px; line-height:58px; border-radius:50%; }
      .n-card h3 { font-family:var(--serif); font-weight:600; font-size:24px; color:var(--sage-dark); margin:16px 0 8px; }
      .n-card p { font-weight:300; font-size:14px; color:var(--soft); line-height:1.6; min-height:46px; }
      .n-card a { display:inline-block; margin-top:16px; font-size:13px; letter-spacing:.1em; text-transform:uppercase; color:var(--gold) !important;
        border:1px solid var(--gold); border-radius:999px; padding:10px 26px; cursor:pointer; transition:all .15s; }
      .n-card a:hover { background:var(--gold); color:#fff !important; }

      /* ===== gratitude band ===== */
      .n-band { max-width:820px; margin:60px auto 80px; padding:0 22px; text-align:center; }
      .n-band .q { font-family:var(--serif); font-style:italic; font-size:clamp(24px,3.4vw,32px); color:var(--sage); line-height:1.45; }
      .n-band .q em { color:var(--gold); font-style:italic; }
      .n-band a { display:inline-block; margin-top:22px; font-size:13px; letter-spacing:.12em; text-transform:uppercase; color:var(--gold) !important; border-bottom:1px solid var(--gold); padding-bottom:3px; }

      /* ===== footer ===== */
      .n-footer { background:linear-gradient(175deg,var(--sage) 0%,var(--sage-dark) 100%); color:#d8d7cf; padding:56px 22px 26px; }
      .n-foot-grid { max-width:1080px; margin:0 auto; display:grid; grid-template-columns:1.2fr 1fr 1.2fr; gap:44px; }
      .n-foot-brand img { width:74px; background:#fff; border-radius:50%; padding:8px; }
      .n-foot-brand .w { font-family:var(--serif); font-size:19px; letter-spacing:.14em; text-transform:uppercase; color:#fff; margin:14px 0 10px; }
      .n-foot-brand p { font-weight:300; font-size:13.5px; line-height:1.7; color:#b9b8ae; max-width:300px; }
      .n-foot h4 { font-family:var(--serif); font-size:17px; letter-spacing:.1em; text-transform:uppercase; color:#ecd9b4; margin:0 0 16px; font-weight:600; }
      .n-foot-links a { display:block; color:#d8d7cf !important; font-weight:300; font-size:14px; padding:5px 0; }
      .n-foot-links a:hover { color:#fff !important; }
      .n-foot-contact div { font-weight:300; font-size:13.5px; line-height:1.8; color:#b9b8ae; }
      .n-foot-contact a { color:#d8d7cf !important; }
      .n-mail { display:flex; margin:14px 0 8px; border:1px solid rgba(255,255,255,.25); border-radius:999px; overflow:hidden; max-width:320px; }
      .n-mail input { flex:1; background:transparent; border:none; outline:none; color:#fff; font-family:var(--sans); font-size:14px; padding:12px 18px; }
      .n-mail input::placeholder { color:rgba(255,255,255,.5); }
      .n-mail button { background:var(--gold); color:#fff; border:none; padding:0 20px; cursor:pointer; font-size:14px; }
      .n-mail button:hover { background:#a3854f; }
      .n-copy { max-width:1080px; margin:44px auto 0; padding-top:18px; border-top:1px solid rgba(255,255,255,.14); text-align:center;
        font-weight:300; font-size:12px; color:#96958a; line-height:1.8; }

      @media (max-width:900px) {
        .n-links { display:none; }
        .n-burger { display:block; }
        .n-foot-grid { grid-template-columns:1fr; gap:34px; }
      }
    </style>
</head>
<body>
<div class="n-page">

  <!-- ===== NAV ===== -->
  <div class="n-nav">
    <div class="n-nav-in">
      <a class="n-brand" href="/">
        <img src="../assets/images/bridalshowerpic.jpg" alt="">
        <span>Detroit<br>Bridal Shower</span>
      </a>
      <div class="n-links">
        <a href="about">About</a>
        <a href="/give">Give a Gift</a>
        <a href="/contributors">With Gratitude</a>
        <a onclick="openPDF()" style="cursor:pointer;">Shopping Guide</a>
        <a href="contact">Contact</a>
        <a class="n-cta" id="showForm">Add a Couple</a>
      </div>
      <button class="n-burger" onclick="document.querySelector('.n-mobile').classList.toggle('open')"><i class="fa-solid fa-bars"></i></button>
    </div>
    <div class="n-mobile">
      <a onclick="openCoupleForm(); document.querySelector('.n-mobile').classList.remove('open')" style="color:var(--gold); cursor:pointer;">+ Add a Couple</a>
      <a href="/give">Give a Gift</a>
      <a href="/contributors">With Gratitude</a>
      <a href="about">About</a>
      <a onclick="openPDF()" style="cursor:pointer;">Shopping Guide</a>
      <a href="contact">Contact</a>
      <a href="financialAssistance">Financial Assistance</a>
    </div>
  </div>

  <!-- ===== HERO ===== -->
  <div class="n-hero">
    <img src="../assets/images/bridalshowerpic.jpg" alt="Detroit Bridal Shower">
    <div class="n-kicker">A Detroit community tradition</div>
    <h1>Every new home begins<br><em>with all of us</em></h1>
    <p>When a chosson and kallah get engaged, our community comes together to gift them the essentials for their new home &mdash; one simcha at a time.</p>
    <div class="n-ctas">
      <a class="n-btn n-btn-gold" onclick="openCoupleForm()">Add a Couple</a>
      <a class="n-btn n-btn-line" href="/give">Give a Gift</a>
    </div>
    <div class="n-orn"><i class="fa-regular fa-heart"></i></div>
  </div>

  <!-- ===== HOW IT WORKS ===== -->
  <div class="n-how">
    <div class="n-label">How it works</div>
    <div class="n-how-grid">
      <div class="n-step">
        <div class="num">1</div>
        <h3>A couple gets engaged</h3>
        <p>Family or friends add the chosson and kallah here &mdash; it takes two minutes, and the community hears the good news.</p>
      </div>
      <div class="n-step">
        <div class="num">2</div>
        <h3>The community gives</h3>
        <p>Friends and neighbors each give toward the couple's bridal shower &mdash; the suggested gift is $65, and every amount helps.</p>
      </div>
      <div class="n-step">
        <div class="num">3</div>
        <h3>A home is built</h3>
        <p>Every dollar goes to the essentials &mdash; from the cholent pot to the linens &mdash; that turn a new apartment into a home.</p>
      </div>
    </div>
  </div>

  <!-- ===== ACTIONS ===== -->
  <div class="n-actions">
    <div class="n-label" id="services">Take part</div>
    <div class="n-cards">
      <div class="n-card">
        <i class="fa-solid fa-user-group"></i>
        <h3>Add a Couple</h3>
        <p>Just got engaged? Share the simcha and start their bridal shower.</p>
        <a onclick="openCoupleForm()">Open the form</a>
      </div>
      <div class="n-card">
        <i class="fa-solid fa-hand-holding-heart"></i>
        <h3>Give a Gift</h3>
        <p>Pick the couples you'd like to give toward &mdash; it takes under a minute.</p>
        <a href="/give">Give now</a>
      </div>
      <div class="n-card">
        <i class="fa-solid fa-heart"></i>
        <h3>With Gratitude</h3>
        <p>See the friends and family who gave toward each couple's shower.</p>
        <a href="/contributors">View couples</a>
      </div>
      <div class="n-card">
        <i class="fa-solid fa-bag-shopping"></i>
        <h3>Shopping Guide</h3>
        <p>Setting up a home? Our guide makes the shopping list simple.</p>
        <a onclick="openPDF()">Open the guide</a>
      </div>
    </div>
  </div>

  <!-- ===== GRATITUDE BAND ===== -->
  <div class="n-band">
    <div class="q">&ldquo;The Detroit Bridal Shower Project has helped countless newlyweds begin life together with a fully stocked home &mdash; <em>because this community shows up for every simcha.</em>&rdquo;</div>
    <a href="/contributors">See who gave &rarr;</a>
  </div>

