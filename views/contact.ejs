<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contact &mdash; Detroit Bridal Shower</title>
<link rel="icon" href="../assets/images/bridalshowerpic.jpg">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root { --ivory:#f4f1ea; --sage:#494e46; --sage-dark:#383c36; --gold:#b3925a; --ink:#2e2e29; --soft:#6d6d64; --line:#e7e2d8;
    --serif:'Cormorant Garamond',Georgia,serif; --sans:'Jost','Segoe UI',sans-serif; }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--ivory); font-family:var(--sans); color:var(--ink); }
  a { text-decoration:none; }
  .n-nav { position:sticky; top:0; z-index:50; background:rgba(244,241,234,.92); backdrop-filter:blur(10px); border-bottom:1px solid var(--line); }
  .n-nav-in { max-width:1180px; margin:0 auto; padding:14px 22px; display:flex; align-items:center; gap:26px; }
  .n-brand { display:flex; align-items:center; gap:12px; }
  .n-brand img { width:44px; height:44px; object-fit:contain; background:#fff; border-radius:50%; padding:4px; border:1px solid var(--line); }
  .n-brand span { font-family:var(--serif); font-weight:600; font-size:17px; letter-spacing:.14em; text-transform:uppercase; color:var(--sage-dark); line-height:1.2; }
  .n-links { display:flex; align-items:center; gap:26px; margin-left:auto; }
  .n-links a { font-size:13.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--sage); }
  .n-links a:hover { color:var(--gold); }
  .n-cta { background:var(--gold); color:#fff !important; border-radius:999px; padding:11px 24px; }
  @media (max-width:820px){ .n-links a:not(.n-cta){ display:none; } }
  .hero { text-align:center; padding:60px 20px 10px; }
  .hero img { width:110px; margin:0 auto 16px; display:block; }
  .kicker { font-size:12px; letter-spacing:5px; text-transform:uppercase; color:var(--gold); font-weight:500; }
  .hero h1 { font-family:var(--serif); font-style:italic; font-weight:500; font-size:clamp(36px,5vw,48px); color:var(--gold); margin:12px 0 8px; }
  .hero p { font-family:var(--serif); font-size:20px; color:var(--soft); line-height:1.6; max-width:460px; margin:0 auto; }
  .wrap { max-width:560px; margin:26px auto 60px; padding:0 18px; }
  .card { background:#fff; border:1px solid var(--line); border-radius:18px; padding:28px 26px 30px; box-shadow:0 10px 30px -18px rgba(56,60,54,.25); }
  .row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  @media (max-width:520px){ .row { grid-template-columns:1fr; } }
  label { display:block; font-size:11.5px; letter-spacing:.08em; color:var(--soft); margin:14px 0 5px; text-transform:uppercase; }
  input, textarea { width:100%; padding:12px 14px; border:1px solid var(--line); border-radius:10px; font-size:15px; font-family:var(--sans); outline:none; background:#fff; }
  input:focus, textarea:focus { border-color:var(--gold); box-shadow:0 0 0 3px rgba(179,146,90,.13); }
  textarea { min-height:130px; resize:vertical; }
  button { width:100%; margin-top:20px; border:none; border-radius:999px; padding:15px; background:var(--gold); color:#fff; font-family:var(--sans); font-size:15.5px; letter-spacing:.05em; cursor:pointer; }
  button:hover { background:#a3854f; }
  .alt { text-align:center; margin-top:26px; font-weight:300; font-size:14px; color:var(--soft); line-height:2; }
  .alt a { color:var(--gold); }
  .foot { text-align:center; padding:10px 20px 40px; font-weight:300; font-size:12.5px; color:var(--soft); }
</style>
</head>
<body>
<div class="n-nav"><div class="n-nav-in">
  <a class="n-brand" href="/"><img src="../assets/images/bridalshowerpic.jpg" alt=""><span>Detroit<br>Bridal Shower</span></a>
  <div class="n-links">
    <a href="/about">About</a>
    <a href="/give">Give a Gift</a>
    <a href="/contributors">With Gratitude</a>
    <a class="n-cta" href="/#services">Add a Couple</a>
  </div>
</div></div>

<div class="hero">
  <img src="../assets/images/bridalshowerpic.jpg" alt="Detroit Bridal Shower">
  <div class="kicker">We'd love to hear from you</div>
  <h1>Get in Touch</h1>
  <p>Questions about a shower, a couple, or how to take part? Send a note and we'll get right back to you.</p>
</div>

<div class="wrap">
  <div class="card">
    <form action="/contact/message" method="POST">
      <div class="row">
        <div><label>First name</label><input type="text" name="First_Name" required></div>
        <div><label>Last name</label><input type="text" name="Last_Name" required></div>
      </div>
      <div class="row">
        <div><label>Email</label><input type="email" name="Email" required></div>
        <div><label>Phone</label><input type="tel" name="Phone_Number"></div>
      </div>
      <label>Message</label>
      <textarea name="Message" required placeholder="How can we help?"></textarea>
      <button type="submit">Send Message</button>
    </form>
  </div>
  <div class="alt">
    Prefer email or phone?<br>
    <a href="mailto:bridalshower@detroitbridalshower.org">bridalshower@detroitbridalshower.org</a> &bull; <a href="tel:2485147963">248-514-7963</a><br>
    17322 Goldwin Drive, Southfield, MI 48075
  </div>
</div>

<div class="foot">&copy; Detroit Bridal Shower Project &middot; 501(c)(4) not-for-profit</div>
</body>
</html>
