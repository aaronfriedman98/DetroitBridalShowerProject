<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard &mdash; Detroit Bridal Shower</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --ivory: #faf7f2;
      --card: #fffdfa;
      --sage: #6b7066;
      --sage-deep: #494e46;
      --sage-darker: #383c36;
      --sage-soft: #eef0ec;
      --gold: #b3925a;
      --gold-soft: #f3ead9;
      --blush: #e9dad3;
      --ink: #2e2e29;
      --ink-soft: #6d6d64;
      --line: #e7e2d8;
      --danger: #b05252;
      --danger-soft: #f6e4e4;
      --ok: #5f7d5f;
      --ok-soft: #e5eee5;
      --serif: 'Cormorant Garamond', Georgia, serif;
      --sans: 'Jost', 'Segoe UI', sans-serif;
      --shadow: 0 1px 2px rgba(56,60,54,.05), 0 8px 24px -12px rgba(56,60,54,.18);
      --shadow-lg: 0 24px 60px -20px rgba(40,42,38,.35);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--sans);
      background: var(--ivory);
      color: var(--ink);
      height: 100vh;
      overflow: hidden;
      -webkit-font-smoothing: antialiased;
    }
    button { font-family: var(--sans); cursor: pointer; }
    input, select, textarea { font-family: var(--sans); }

    /* ---------- layout ---------- */
    .app { display: flex; height: 100vh; }

    /* ---------- sidebar ---------- */
    .sidebar {
      width: 232px;
      background: linear-gradient(175deg, var(--sage-deep) 0%, var(--sage-darker) 100%);
      color: #efeee9;
      display: flex; flex-direction: column;
      position: fixed; inset: 0 auto 0 0;
      z-index: 40;
      padding: 28px 18px 22px;
    }
    .brand { text-align: center; padding-bottom: 24px; border-bottom: 1px solid rgba(255,255,255,.12); }
    .brand .medallion {
      width: 92px; height: 92px; border-radius: 50%;
      background: #fff; margin: 0 auto 12px;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 0 0 4px rgba(255,255,255,.12), 0 8px 20px -8px rgba(0,0,0,.5);
      overflow: hidden;
    }
    .brand .medallion img { width: 74%; height: 74%; object-fit: contain; }
    .brand h1 {
      font-family: var(--serif); font-weight: 600; font-size: 21px;
      letter-spacing: .12em; text-transform: uppercase; line-height: 1.35;
    }
    .brand span { display: block; font-family: var(--sans); font-weight: 300; font-size: 10.5px; letter-spacing: .38em; text-transform: uppercase; color: #cdbf9d; margin-top: 6px; }
    .nav { margin-top: 26px; display: flex; flex-direction: column; gap: 4px; flex: 1; }
    .nav a {
      display: flex; align-items: center; gap: 12px;
      color: #d8d7cf; text-decoration: none;
      font-size: 14.5px; font-weight: 400; letter-spacing: .04em;
      padding: 11px 14px; border-radius: 10px;
      transition: background .18s, color .18s;
    }
    .nav a svg { width: 17px; height: 17px; flex: none; opacity: .8; }
    .nav a:hover { background: rgba(255,255,255,.07); color: #fff; }
    .nav a.active { background: rgba(179,146,90,.18); color: #ecd9b4; }
    .nav a.active svg { opacity: 1; }
    .sidebar .foot { font-size: 11px; color: rgba(255,255,255,.35); text-align: center; letter-spacing: .08em; }

    /* ---------- main ---------- */
    .main {
      flex: 1; margin-left: 232px; padding: 26px 36px 26px; max-width: 1400px;
      height: 100vh; display: flex; flex-direction: column; min-height: 0; overflow: hidden;
    }
    .topbar { display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; flex-wrap: wrap; margin-bottom: 26px; }
    .topbar h2 { font-family: var(--serif); font-weight: 600; font-size: 34px; color: var(--sage-darker); line-height: 1.1; }
    .topbar .date { color: var(--ink-soft); font-size: 13.5px; font-weight: 300; letter-spacing: .06em; margin-top: 4px; }
    .topbar-actions { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }

    .search-wrap { position: relative; }
    .search-wrap svg { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); width: 15px; height: 15px; color: var(--ink-soft); }
    .search-wrap input {
      width: 250px; padding: 11px 14px 11px 38px;
      border: 1px solid var(--line); border-radius: 999px;
      background: var(--card); font-size: 14px; color: var(--ink);
      outline: none; transition: border .18s, box-shadow .18s;
    }
    .search-wrap input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(179,146,90,.15); }

    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      border: none; border-radius: 999px;
      padding: 11px 20px; font-size: 14px; font-weight: 500; letter-spacing: .03em;
      transition: transform .15s, box-shadow .15s, background .15s, opacity .15s;
    }
    .btn:active { transform: scale(.97); }
    .btn svg { width: 15px; height: 15px; }
    .btn-gold { background: var(--gold); color: #fff; box-shadow: 0 6px 16px -6px rgba(179,146,90,.6); }
    .btn-gold:hover { background: #a3854f; }
    .btn-sage { background: var(--sage-deep); color: #fff; }
    .btn-sage:hover { background: var(--sage-darker); }
    .btn-ghost { background: transparent; color: var(--sage-deep); border: 1px solid var(--line); }
    .btn-ghost:hover { background: var(--sage-soft); }
    .btn-danger { background: var(--danger); color: #fff; }
    .btn-danger:hover { background: #9a4444; }
    .btn[disabled] { opacity: .55; pointer-events: none; }

    /* ---------- stats ---------- */
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 16px; margin-bottom: 24px; }
    .stat {
      background: var(--card); border: 1px solid var(--line); border-radius: 16px;
      padding: 18px 20px; box-shadow: var(--shadow);
      display: flex; align-items: center; gap: 15px;
    }
    .stat .ico {
      width: 44px; height: 44px; border-radius: 12px;
      display: grid; place-items: center; flex: none;
    }
    .stat .ico svg { width: 20px; height: 20px; }
    .stat b { display: block; font-family: var(--serif); font-size: 27px; font-weight: 600; color: var(--sage-darker); line-height: 1; }
    .stat span { font-size: 12px; color: var(--ink-soft); letter-spacing: .09em; text-transform: uppercase; font-weight: 400; }

    /* ---------- pending banner ---------- */
    .pending {
      display: none;
      background: linear-gradient(120deg, var(--gold-soft), #fdf9f0 55%);
      border: 1px solid #e5d5b4; border-radius: 16px;
      padding: 18px 22px; margin-bottom: 24px;
      align-items: center; gap: 18px; flex-wrap: wrap;
      box-shadow: var(--shadow);
    }
    .pending.show { display: flex; }
    .pending .tag {
      font-size: 10.5px; letter-spacing: .22em; text-transform: uppercase;
      background: var(--gold); color: #fff; border-radius: 999px; padding: 5px 12px; font-weight: 500;
    }
    .pending .names { font-family: var(--serif); font-size: 21px; font-weight: 600; color: var(--sage-darker); flex: 1; min-width: 200px; }
    .pending .names em { font-style: normal; color: var(--gold); padding: 0 4px; }
    .pending .sub { display: block; font-family: var(--sans); font-size: 12.5px; color: var(--ink-soft); font-weight: 300; margin-top: 2px; letter-spacing: .04em; }

    /* ---------- content grid ---------- */
    .grid {
      display: grid; grid-template-columns: 1fr 330px; gap: 22px;
      align-items: stretch; flex: 1; min-height: 0;
    }

    .card {
      background: var(--card); border: 1px solid var(--line); border-radius: 18px;
      box-shadow: var(--shadow); overflow: hidden;
      display: flex; flex-direction: column; min-height: 0;
    }
    .card-head {
      display: flex; align-items: center; justify-content: space-between; gap: 14px;
      padding: 18px 22px 14px; flex-wrap: wrap;
    }
    .card-head h3 { font-family: var(--serif); font-size: 22px; font-weight: 600; color: var(--sage-darker); }
    .card-head .count { font-size: 12px; color: var(--ink-soft); font-weight: 300; letter-spacing: .05em; }

    .chips { display: flex; gap: 8px; flex-wrap: wrap; padding: 0 22px 14px; }
    .chip {
      border: 1px solid var(--line); background: transparent; color: var(--ink-soft);
      font-size: 12.5px; padding: 6px 14px; border-radius: 999px; letter-spacing: .04em;
      transition: all .15s;
    }
    .chip:hover { border-color: var(--sage); color: var(--sage-deep); }
    .chip.active { background: var(--sage-deep); border-color: var(--sage-deep); color: #fff; }

    /* ---------- table ---------- */
    .table-wrap { flex: 1; min-height: 0; overflow-y: auto; }
    table { width: 100%; border-collapse: collapse; table-layout: fixed; }
    col.c-couple { width: auto; }
    col.c-added { width: 112px; }
    col.c-status { width: 108px; }
    col.c-collect { width: 120px; }
    col.c-actions { width: 128px; }
    thead th {
      position: sticky; top: 0; z-index: 2;
      background: var(--card);
      text-align: left; font-size: 11px; font-weight: 500; letter-spacing: .16em; text-transform: uppercase;
      color: var(--ink-soft); padding: 10px 14px; border-bottom: 1px solid var(--line);
    }
    thead th:first-child, tbody td:first-child { padding-left: 22px; }
    tbody td { padding: 13px 14px; border-bottom: 1px solid #f0ece3; font-size: 14px; vertical-align: middle; }
    tbody tr { transition: background .12s; }
    tbody tr:hover { background: #fbf8f1; }
    .couple-names { font-weight: 500; color: var(--ink); line-height: 1.35; }
    .couple-names small { display: block; font-weight: 300; color: var(--ink-soft); font-size: 12px; letter-spacing: .03em; }
    .added { font-size: 12.5px; color: var(--ink-soft); font-weight: 300; white-space: nowrap; }

    .badge {
      display: inline-block; font-size: 10.5px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
      border-radius: 999px; padding: 4px 10px; white-space: nowrap;
    }
    .badge.collecting { background: var(--ok-soft); color: var(--ok); }
    .badge.pending { background: var(--gold-soft); color: var(--gold); }
    .badge.idle { background: #efede7; color: #97968c; }

    .row-actions { display: flex; gap: 4px; justify-content: flex-end; }
    .icon-btn {
      width: 32px; height: 32px; border-radius: 9px; border: none; background: transparent;
      display: grid; place-items: center; color: #8b8b80;
      transition: background .15s, color .15s;
    }
    .icon-btn svg { width: 16px; height: 16px; }
    .icon-btn:hover { background: var(--sage-soft); color: var(--sage-darker); }
    .icon-btn.danger:hover { background: var(--danger-soft); color: var(--danger); }

    /* collect switch */
    .switch { position: relative; width: 40px; height: 22px; flex: none; cursor: pointer; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .switch .track {
      position: absolute; inset: 0; border-radius: 999px; background: #ddd9cf; transition: background .2s;
    }
    .switch .track::after {
      content: ''; position: absolute; top: 3px; left: 3px; width: 16px; height: 16px;
      border-radius: 50%; background: #fff; box-shadow: 0 1px 3px rgba(0,0,0,.25); transition: transform .2s;
    }
    .switch input:checked + .track { background: var(--ok); }
    .switch input:checked + .track::after { transform: translateX(18px); }
    .switch-cell { display: inline-flex; align-items: center; gap: 8px; }
    .switch-state { font-size: 10.5px; font-weight: 500; letter-spacing: .12em; text-transform: uppercase; width: 26px; text-align: left; }
    .switch-state.on { color: var(--ok); }
    .switch-state.off { color: #b3b1a6; }

    .empty { padding: 40px 22px; text-align: center; color: var(--ink-soft); font-weight: 300; font-size: 14px; }

    /* ---------- collection panel ---------- */
    .collection-list { flex: 1; min-height: 0; overflow-y: auto; padding: 4px 14px 16px; }
    .collection-item {
      display: flex; align-items: center; gap: 12px;
      padding: 11px 10px; border-radius: 12px;
      transition: background .12s;
    }
    .collection-item:hover { background: #faf6ee; }
    .collection-item .heart { color: var(--blush); flex: none; }
    .collection-item .heart svg { width: 14px; height: 14px; display: block; color: #cfa9a0; }
    .collection-item p { font-size: 14px; line-height: 1.35; flex: 1; }
    .collection-item p b { font-weight: 500; }
    .collection-item .mini {
      border: none; background: transparent; color: #b6b4a9; width: 28px; height: 28px;
      display: grid; place-items: center; border-radius: 8px;
    }
    .collection-item .mini:hover { background: var(--sage-soft); color: var(--sage-darker); }
    .collection-item .mini svg { width: 15px; height: 15px; }
    .send-note { padding: 0 22px 18px; font-size: 12px; color: var(--ink-soft); font-weight: 300; line-height: 1.5; }

    /* ---------- modals ---------- */
    .overlay {
      position: fixed; inset: 0; z-index: 90;
      background: rgba(40,42,38,.45); backdrop-filter: blur(3px);
      display: none; align-items: flex-start; justify-content: center;
      padding: 5vh 18px 18px; overflow-y: auto;
    }
    .overlay.show { display: flex; }
    .modal {
      background: var(--card); border-radius: 20px; box-shadow: var(--shadow-lg);
      width: 100%; max-width: 680px; overflow: hidden;
      animation: pop .22s cubic-bezier(.2,.9,.3,1.2);
    }
    .modal.narrow { max-width: 440px; }
    @keyframes pop { from { transform: scale(.94) translateY(8px); opacity: 0; } to { transform: none; opacity: 1; } }
    .modal-head {
      padding: 22px 26px 0; display: flex; align-items: flex-start; justify-content: space-between; gap: 14px;
    }
    .modal-head h3 { font-family: var(--serif); font-size: 25px; font-weight: 600; color: var(--sage-darker); line-height: 1.2; }
    .modal-head .x {
      border: none; background: var(--sage-soft); color: var(--sage-deep);
      width: 32px; height: 32px; border-radius: 50%; font-size: 16px; line-height: 1; flex: none;
    }
    .modal-head .x:hover { background: var(--blush); }
    .modal-body { padding: 18px 26px 26px; }
    .modal-foot { display: flex; justify-content: flex-end; gap: 10px; padding: 0 26px 24px; flex-wrap: wrap; }

    .fieldset-label {
      font-size: 11px; letter-spacing: .2em; text-transform: uppercase; color: var(--gold);
      font-weight: 500; margin: 18px 0 10px; display: flex; align-items: center; gap: 10px;
    }
    .fieldset-label::after { content: ''; height: 1px; background: var(--line); flex: 1; }
    .fieldset-label:first-child { margin-top: 0; }
    .frow { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
    .frow.thirds { grid-template-columns: 110px 1fr; }
    .field label { display: block; font-size: 11.5px; color: var(--ink-soft); letter-spacing: .06em; margin-bottom: 4px; }
    .field input, .field select {
      width: 100%; padding: 10px 12px; border: 1px solid var(--line); border-radius: 10px;
      background: #fff; font-size: 14px; color: var(--ink); outline: none;
      transition: border .15s, box-shadow .15s;
    }
    .field input:focus, .field select:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(179,146,90,.13); }
    .field input[readonly], .field select[disabled] { background: #f7f5ef; color: #77766d; border-color: transparent; }

    .confirm-msg { font-size: 15px; line-height: 1.55; color: var(--ink); padding-top: 4px; }

    /* ---------- toast ---------- */
    .toasts { position: fixed; bottom: 22px; right: 22px; z-index: 200; display: flex; flex-direction: column; gap: 10px; }
    .toast {
      background: var(--sage-darker); color: #f4f3ee;
      border-radius: 12px; padding: 13px 18px; font-size: 14px;
      box-shadow: var(--shadow-lg); display: flex; align-items: center; gap: 10px;
      animation: slideup .25s ease; max-width: 340px;
    }
    .toast.err { background: var(--danger); }
    .toast.gold { background: var(--gold); }
    @keyframes slideup { from { transform: translateY(12px); opacity: 0; } to { transform: none; opacity: 1; } }

    /* ---------- loading overlay ---------- */
    .sending {
      position: fixed; inset: 0; z-index: 300; display: none;
      background: rgba(250,247,242,.88); backdrop-filter: blur(4px);
      align-items: center; justify-content: center; flex-direction: column; gap: 18px;
    }
    .sending.show { display: flex; }
    .spinner {
      width: 46px; height: 46px; border-radius: 50%;
      border: 3px solid var(--blush); border-top-color: var(--gold);
      animation: spin .9s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .sending p { font-family: var(--serif); font-size: 21px; color: var(--sage-darker); }
    .sending small { font-size: 13px; color: var(--ink-soft); font-weight: 300; letter-spacing: .04em; margin-top: -10px; }

    /* ---------- responsive ---------- */
    .menu-toggle { display: none; }
    @media (max-width: 1080px) {
      body { overflow: auto; height: auto; }
      .app { height: auto; }
      .main { height: auto; overflow: visible; display: block; }
      .grid { grid-template-columns: 1fr; }
      .table-wrap { max-height: 62vh; flex: none; }
      .collection-list { max-height: 380px; flex: none; }
    }
    @media (max-width: 860px) {
      .sidebar { transform: translateX(-100%); transition: transform .25s; }
      .sidebar.open { transform: none; }
      .main { margin-left: 0; padding: 22px 16px 50px; }
      .menu-toggle {
        display: grid; place-items: center;
        width: 42px; height: 42px; border-radius: 12px; border: 1px solid var(--line);
        background: var(--card); color: var(--sage-deep);
      }
      .search-wrap input { width: 100%; }
      .topbar-actions { width: 100%; }
      .search-wrap { flex: 1; }
    }
  </style>
</head>
<body>

<div class="app">

  <!-- ============ SIDEBAR ============ -->
  <aside class="sidebar" id="sidebar">
    <div class="brand">
      <div class="medallion">
        <img src="/assets/images/bridalshowerpic.jpg" alt="Detroit Bridal Shower">
      </div>
      <h1>Detroit<br>Bridal Shower</h1>
      <span>Admin</span>
    </div>
    <nav class="nav">
      <a href="/newAdmin" class="active">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg>
        Dashboard
      </a>
      <a href="/adminUpload">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 16V4m0 0L7 9m5-5 5 5"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg>
        Announcements
      </a>
      <a href="/" target="_blank">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M3.5 12h17M12 3c2.5 2.6 3.8 5.7 3.8 9S14.5 18.4 12 21c-2.5-2.6-3.8-5.7-3.8-9S9.5 5.6 12 3z"/></svg>
        View Website
      </a>
    </nav>
    <div class="foot">est. with love &middot; Detroit</div>
  </aside>

  <!-- ============ MAIN ============ -->
  <main class="main">

    <div class="topbar">
      <div style="display:flex; gap:14px; align-items:center;">
        <button class="menu-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')" aria-label="Menu">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
        </button>
        <div>
          <h2>Dashboard</h2>
          <div class="date" id="todayDate"></div>
        </div>
      </div>
      <div class="topbar-actions">
        <button class="btn btn-gold" onclick="openAddModal()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
          Add Couple
        </button>
      </div>
    </div>

    <!-- stats -->
    <div class="stats">
      <div class="stat">
        <div class="ico" style="background:var(--sage-soft); color:var(--sage-deep);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div><b id="statTotal">0</b><span>Total couples</span></div>
      </div>
      <div class="stat">
        <div class="ico" style="background:var(--ok-soft); color:var(--ok);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>
        </div>
        <div><b id="statCollecting">0</b><span>Collecting now</span></div>
      </div>
      <div class="stat">
        <div class="ico" style="background:var(--gold-soft); color:var(--gold);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
        </div>
        <div><b id="statPending">0</b><span>Pending review</span></div>
      </div>
      <div class="stat">
        <div class="ico" style="background:var(--blush); color:#a0766c;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M22 11.1V12a10 10 0 1 1-5.9-9.1"/><path d="m9 11 3 3L22 4"/></svg>
        </div>
        <div><b id="statVerified">0</b><span>Verified all-time</span></div>
      </div>
    </div>

    <!-- review queue banner -->
    <div class="pending" id="pendingBanner">
      <span class="tag" id="pendingTag">Awaiting Review</span>
      <div class="names" id="pendingNames">&nbsp;</div>
      <button class="btn btn-ghost" id="pendingViewBtn">Review Queue</button>
    </div>

    <!-- content grid -->
    <div class="grid">

      <!-- all couples -->
      <div class="card">
        <div class="card-head">
          <div style="display:flex; align-items:baseline; gap:12px;">
            <h3>All Couples</h3>
            <span class="count" id="tableCount"></span>
          </div>
          <div class="search-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.8-3.8"/></svg>
            <input type="search" id="searchInput" placeholder="Search couples..." autocomplete="off">
          </div>
        </div>
        <div class="chips" id="filterChips">
          <button class="chip active" data-filter="all">All</button>
          <button class="chip" data-filter="collecting">Collecting</button>
          <button class="chip" data-filter="unverified">Unverified</button>
          <button class="chip" data-filter="idle">Not collecting</button>
        </div>
        <div class="table-wrap">
          <table>
            <colgroup>
              <col class="c-couple"><col class="c-added"><col class="c-status"><col class="c-collect"><col class="c-actions">
            </colgroup>
            <thead>
              <tr>
                <th>Couple</th>
                <th>Added</th>
                <th>Status</th>
                <th style="text-align:center;">Collecting</th>
                <th style="text-align:right; padding-right:22px;">Actions</th>
              </tr>
            </thead>
            <tbody id="couplesBody"></tbody>
          </table>
          <div class="empty" id="tableEmpty" style="display:none;">No couples match your search.</div>
        </div>
      </div>

      <!-- collection list -->
      <div class="card">
        <div class="card-head">
          <h3>Collection List</h3>
          <span class="count" id="collectionCount"></span>
        </div>
        <div style="padding: 0 22px 14px;">
          <button class="btn btn-sage" style="width:100%; justify-content:center;" id="sendEmailBtn" onclick="sendCollectionEmail()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-11 11"/><path d="M22 2 15 22l-4-9-9-4 20-7z"/></svg>
            Send Collection Email
          </button>
        </div>
        <div class="collection-list" id="collectionList"></div>
        <div class="send-note">Sends the collection newsletter to all subscribers &mdash; featuring the newest couple (if pending) and everyone currently collecting.</div>
      </div>

    </div>
  </main>
</div>

<!-- ============ VIEW / EDIT MODAL ============ -->
<div class="overlay" id="coupleOverlay">
  <div class="modal">
    <div class="modal-head">
      <h3 id="coupleModalTitle">Couple Details</h3>
      <button class="x" onclick="closeOverlay('coupleOverlay')">&times;</button>
    </div>
    <div class="modal-body" id="coupleModalBody"></div>
    <div class="modal-foot" id="coupleModalFoot"></div>
  </div>
</div>

<!-- ============ ADD MODAL ============ -->
<div class="overlay" id="addOverlay">
  <div class="modal">
    <div class="modal-head">
      <h3>Add a Couple</h3>
      <button class="x" onclick="closeOverlay('addOverlay')">&times;</button>
    </div>
    <div class="modal-body" id="addModalBody"></div>
    <div class="modal-foot">
      <button class="btn btn-ghost" onclick="closeOverlay('addOverlay')">Cancel</button>
      <button class="btn btn-gold" id="addSaveBtn" onclick="submitAdd()">Add Couple</button>
    </div>
  </div>
</div>

<!-- ============ CONFIRM MODAL ============ -->
<div class="overlay" id="confirmOverlay">
  <div class="modal narrow">
    <div class="modal-head">
      <h3 id="confirmTitle">Are you sure?</h3>
      <button class="x" onclick="resolveConfirm(false)">&times;</button>
    </div>
    <div class="modal-body"><p class="confirm-msg" id="confirmMsg"></p></div>
    <div class="modal-foot">
      <button class="btn btn-ghost" id="confirmNoBtn" onclick="resolveConfirm(false)">Cancel</button>
      <button class="btn btn-gold" id="confirmYesBtn" onclick="resolveConfirm(true)">Confirm</button>
    </div>
  </div>
</div>

<!-- sending overlay -->
<div class="sending" id="sendingOverlay">
  <div class="spinner"></div>
  <p id="sendingText">Sending email&hellip;</p>
  <small>This can take a minute &mdash; please keep this tab open.</small>
</div>

<div class="toasts" id="toasts"></div>

<script>
/* ================= initial state (rendered by server) ================= */
let state = {
  couples: <%- JSON.stringify(coupleInfo).replace(/</g, '\\u003c') %>,
  newCouple: <%- JSON.stringify(newCouple).replace(/</g, '\\u003c') %>
};
let searchTerm = '';
let activeFilter = 'all';

/* ================= helpers ================= */
const $ = (id) => document.getElementById(id);
const esc = (s) => String(s == null ? '' : s)
  .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

function addedDate(id) {
  const d = new Date(parseInt(String(id).substring(0, 8), 16) * 1000);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
function pendingTempId() {
  return state.newCouple.length ? String(state.newCouple[0].tempId) : null;
}
function toast(msg, type) {
  const t = document.createElement('div');
  t.className = 'toast' + (type ? ' ' + type : '');
  t.textContent = msg;
  $('toasts').appendChild(t);
  setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity .4s'; }, 3200);
  setTimeout(() => t.remove(), 3700);
}
function closeOverlay(id) { $(id).classList.remove('show'); }

/* promise-based confirm modal */
let confirmResolver = null;
function askConfirm(message, opts) {
  opts = opts || {};
  $('confirmTitle').textContent = opts.title || 'Are you sure?';
  $('confirmMsg').innerHTML = message;
  const yes = $('confirmYesBtn');
  yes.textContent = opts.yesText || 'Confirm';
  yes.className = 'btn ' + (opts.danger ? 'btn-danger' : 'btn-gold');
  $('confirmNoBtn').textContent = opts.noText || 'Cancel';
  $('confirmOverlay').classList.add('show');
  return new Promise((resolve) => { confirmResolver = resolve; });
}
function resolveConfirm(val) {
  closeOverlay('confirmOverlay');
  if (confirmResolver) { confirmResolver(val); confirmResolver = null; }
}

async function refreshData() {
  try {
    const res = await fetch('/newAdmin/data');
    if (!res.ok) throw new Error();
    const data = await res.json();
    state.couples = data.couples;
    state.newCouple = data.newCouple;
    renderAll();
  } catch (e) {
    toast('Could not refresh data — reload the page.', 'err');
  }
}

/* ================= rendering ================= */
function renderAll() { renderStats(); renderPending(); renderTable(); renderCollection(); }

function renderStats() {
  $('statTotal').textContent = state.couples.length;
  $('statCollecting').textContent = state.couples.filter(c => c.collecting).length;
  $('statPending').textContent = state.couples.filter(c => !c.verified).length;
  $('statVerified').textContent = state.couples.filter(c => c.verified).length;
}

function renderPending() {
  // review queue: couples submitted but never verified, newest first
  const banner = $('pendingBanner');
  const queue = state.couples.filter(c => !c.verified);
  if (!queue.length) { banner.classList.remove('show'); return; }

  const shown = queue.slice(0, 3)
    .map(c => esc(c.chossonName) + ' <em>&amp;</em> ' + esc(c.kallahName))
    .join('<span style="color:var(--gold); padding:0 8px;">&bull;</span>');
  const more = queue.length > 3 ? ' <span class="sub" style="display:inline;">+ ' + (queue.length - 3) + ' more</span>' : '';
  $('pendingTag').textContent = queue.length === 1 ? 'Awaiting Review' : queue.length + ' Awaiting Review';
  $('pendingNames').innerHTML = shown + more +
    '<span class="sub">Turn on collecting to verify a couple &amp; send their announcement</span>';
  $('pendingViewBtn').onclick = () => {
    activeFilter = 'unverified';
    document.querySelectorAll('.chip').forEach(ch => ch.classList.toggle('active', ch.dataset.filter === 'unverified'));
    renderTable();
    document.querySelector('.table-wrap').scrollTop = 0;
  };
  banner.classList.add('show');
}

function visibleCouples() {
  const q = searchTerm.trim().toLowerCase();
  return state.couples.filter(c => {
    if (activeFilter === 'collecting' && !c.collecting) return false;
    if (activeFilter === 'unverified' && c.verified) return false;
    if (activeFilter === 'idle' && (c.collecting || !c.verified)) return false;
    if (!q) return true;
    return ['chossonName', 'kallahName', 'name', 'email'].some(f =>
      String(c[f] || '').toLowerCase().includes(q));
  });
}

function renderTable() {
  const rows = visibleCouples();
  $('tableCount').textContent = rows.length + ' of ' + state.couples.length;
  $('tableEmpty').style.display = rows.length ? 'none' : 'block';
  $('couplesBody').innerHTML = rows.map(c => {
    const badge = c.collecting
      ? '<span class="badge collecting">Collecting</span>'
      : (c.verified ? '<span class="badge idle">Done</span>' : '<span class="badge pending">Unverified</span>');
    return `
      <tr data-id="${c._id}">
        <td>
          <div class="couple-names">${esc(c.chossonName)} &amp; ${esc(c.kallahName)}
            <small>${esc(c.name || '')}</small>
          </div>
        </td>
        <td><span class="added">${addedDate(c._id)}</span></td>
        <td>${badge}</td>
        <td style="text-align:center;">
          <span class="switch-cell">
            <label class="switch" title="Toggle collecting (verifies the couple)">
              <input type="checkbox" ${c.collecting ? 'checked' : ''} onchange="toggleCollecting('${c._id}', this)">
              <span class="track"></span>
            </label>
            <span class="switch-state ${c.collecting ? 'on' : 'off'}">${c.collecting ? 'On' : 'Off'}</span>
          </span>
        </td>
        <td>
          <div class="row-actions">
            <button class="icon-btn" title="View details" onclick="openCoupleModal('${c._id}', false)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            <button class="icon-btn" title="Edit" onclick="openCoupleModal('${c._id}', true)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M17 3a2.85 2.85 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5z"/></svg>
            </button>
            <button class="icon-btn danger" title="Delete" onclick="deleteCouple('${c._id}')">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M3 6h18M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M10 11v6M14 11v6"/></svg>
            </button>
          </div>
        </td>
      </tr>`;
  }).join('');
}

function renderCollection() {
  const collecting = state.couples.filter(c => c.collecting);
  $('collectionCount').textContent = collecting.length + ' active';
  const tempId = pendingTempId();
  let html = '';

  if (state.newCouple.length) {
    const nc = state.newCouple[0];
    html += `
      <div class="collection-item" style="background: var(--gold-soft); margin-bottom: 6px;">
        <span class="heart"><svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg></span>
        <p><b>${esc(nc.chosson)} &amp; ${esc(nc.kallah)}</b><br><span style="font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--gold);">Featured next send</span></p>
      </div>`;
  }

  html += collecting
    .filter(c => !tempId || String(c._id) !== tempId)
    .map(c => `
      <div class="collection-item">
        <span class="heart"><svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg></span>
        <p>${esc(c.chossonName)} &amp;<br>${esc(c.kallahName)}</p>
        <button class="mini" title="View details" onclick="openCoupleModal('${c._id}', false)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 8h.01"/></svg>
        </button>
      </div>`).join('');

  $('collectionList').innerHTML = html || '<div class="empty">No couples are collecting right now.</div>';
}

/* ================= couple form fields ================= */
const TITLE_F = ['Mr.', 'Rabbi', 'Dr.'];
const TITLE_M = ['Mrs.', 'Rebbetzin', 'Dr.'];

function fieldHTML(def, value, editable) {
  const v = value == null ? '' : value;
  if (def.type === 'select') {
    const opts = def.options.map(o =>
      `<option value="${esc(o.v)}" ${String(v) === o.v ? 'selected' : ''}>${esc(o.t)}</option>`).join('');
    return `<div class="field"><label>${def.label}</label>
      <select id="f_${def.key}" ${editable ? '' : 'disabled'}>${def.optional ? '<option value="">—</option>' : ''}${opts}</select></div>`;
  }
  return `<div class="field"><label>${def.label}</label>
    <input type="${def.type || 'text'}" id="f_${def.key}" value="${esc(v)}" ${editable ? '' : 'readonly'}></div>`;
}

function coupleFormHTML(c, editable) {
  c = c || {};
  const sel = (opts) => opts.map(o => ({ v: o, t: o }));
  return `
    <div class="fieldset-label">Chosson</div>
    <div class="frow">
      ${fieldHTML({ key: 'chossonName', label: 'Full name' }, c.chossonName, editable)}
      ${fieldHTML({ key: 'chossonOrigin', label: 'From', type: 'select', options: [{v:'detroit',t:'Detroit'},{v:'other',t:'Other'}] }, c.chossonOrigin || 'detroit', editable)}
    </div>
    <div class="frow thirds">
      ${fieldHTML({ key: 'chossonFatherTitle', label: 'Title', type: 'select', optional: true, options: sel(TITLE_F) }, c.chossonFatherTitle, editable)}
      ${fieldHTML({ key: 'chossonFather', label: "Father's name" }, c.chossonFather, editable)}
    </div>
    <div class="frow thirds">
      ${fieldHTML({ key: 'chossonMotherTitle', label: 'Title', type: 'select', optional: true, options: sel(TITLE_M) }, c.chossonMotherTitle, editable)}
      ${fieldHTML({ key: 'chossonMother', label: "Mother's name" }, c.chossonMother, editable)}
    </div>

    <div class="fieldset-label">Kallah</div>
    <div class="frow">
      ${fieldHTML({ key: 'kallahName', label: 'Full name' }, c.kallahName, editable)}
      ${fieldHTML({ key: 'kallahOrigin', label: 'From', type: 'select', options: [{v:'detroit',t:'Detroit'},{v:'other',t:'Other'}] }, c.kallahOrigin || 'detroit', editable)}
    </div>
    <div class="frow thirds">
      ${fieldHTML({ key: 'kallahFatherTitle', label: 'Title', type: 'select', optional: true, options: sel(TITLE_F) }, c.kallahFatherTitle, editable)}
      ${fieldHTML({ key: 'kallahFather', label: "Father's name" }, c.kallahFather, editable)}
    </div>
    <div class="frow thirds">
      ${fieldHTML({ key: 'kallahMotherTitle', label: 'Title', type: 'select', optional: true, options: sel(TITLE_M) }, c.kallahMotherTitle, editable)}
      ${fieldHTML({ key: 'kallahMother', label: "Mother's name" }, c.kallahMother, editable)}
    </div>

    <div class="fieldset-label">Contact &amp; Details</div>
    <div class="frow">
      ${fieldHTML({ key: 'name', label: 'Submitted by' }, c.name, editable)}
      ${fieldHTML({ key: 'email', label: 'Email', type: 'email' }, c.email, editable)}
    </div>
    <div class="frow">
      ${fieldHTML({ key: 'phoneNumber', label: 'Phone' }, c.phoneNumber, editable)}
      ${fieldHTML({ key: 'weddingDate', label: 'Wedding date', type: 'date' }, c.weddingDate, editable)}
    </div>
    <div class="frow">
      ${fieldHTML({ key: 'address', label: 'Address' }, c.address, editable)}
      ${fieldHTML({ key: 'personalShopper', label: 'Detroit Chesed Package Gift', type: 'select', optional: true, options: [{v:'yes',t:'Yes'},{v:'no',t:'No'}] }, c.personalShopper, editable)}
    </div>`;
}

function readForm() {
  const keys = ['chossonName','chossonOrigin','chossonFatherTitle','chossonFather','chossonMotherTitle','chossonMother',
                'kallahName','kallahOrigin','kallahFatherTitle','kallahFather','kallahMotherTitle','kallahMother',
                'name','email','phoneNumber','weddingDate','address','personalShopper'];
  const out = {};
  keys.forEach(k => { const el = $('f_' + k); if (el) out[k] = el.value; });
  return out;
}

/* ================= view / edit ================= */
function openCoupleModal(id, editable) {
  const c = state.couples.find(x => String(x._id) === String(id));
  if (!c) return;
  $('coupleModalTitle').textContent = editable ? 'Edit Couple' : (c.chossonName + ' & ' + c.kallahName);
  $('coupleModalBody').innerHTML = coupleFormHTML(c, editable);
  $('coupleModalFoot').innerHTML = editable
    ? `<button class="btn btn-ghost" onclick="closeOverlay('coupleOverlay')">Cancel</button>
       <button class="btn btn-gold" id="saveEditBtn" onclick="saveEdit('${c._id}')">Save Changes</button>`
    : `<button class="btn btn-ghost" onclick="closeOverlay('coupleOverlay')">Close</button>
       <button class="btn btn-sage" onclick="openCoupleModal('${c._id}', true)">Edit</button>`;
  $('coupleOverlay').classList.add('show');
}

async function saveEdit(id) {
  const btn = $('saveEditBtn');
  btn.disabled = true;
  try {
    const res = await fetch('/newAdmin/updateEntry', {
      method: 'put',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(Object.assign({ id }, readForm()))
    });
    const data = await res.json();
    if (!data.status) throw new Error(data.message);
    closeOverlay('coupleOverlay');
    toast('Couple updated.');
    await refreshData();
  } catch (e) {
    toast('Could not save changes.', 'err');
    btn.disabled = false;
  }
}

/* ================= add ================= */
function openAddModal() {
  $('addModalBody').innerHTML = coupleFormHTML({}, true);
  $('addSaveBtn').disabled = false;
  $('addOverlay').classList.add('show');
}

async function submitAdd() {
  const f = readForm();
  if (!f.chossonName || !f.kallahName || !f.name || !f.email || !f.phoneNumber || !f.address) {
    toast('Please fill in the couple names, submitter, email, phone and address.', 'err');
    return;
  }
  const btn = $('addSaveBtn');
  btn.disabled = true;
  try {
    // addEntry expects the *Name variants for parent fields
    const body = Object.assign({}, f, {
      chossonFatherName: f.chossonFather, chossonMotherName: f.chossonMother,
      kallahFatherName: f.kallahFather, kallahMotherName: f.kallahMother
    });
    const res = await fetch('/newAdmin/addEntry', {
      method: 'post',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const data = await res.json();
    if (!data.status) throw new Error(data.message);
    closeOverlay('addOverlay');
    toast('Couple added.');
    await refreshData();
  } catch (e) {
    toast('Could not add the couple.', 'err');
    btn.disabled = false;
  }
}

/* ================= delete ================= */
async function deleteCouple(id) {
  const c = state.couples.find(x => String(x._id) === String(id));
  if (!c) return;
  const yes = await askConfirm(
    'Delete <b>' + esc(c.chossonName) + ' &amp; ' + esc(c.kallahName) + '</b>? This cannot be undone.',
    { title: 'Delete couple', yesText: 'Delete', danger: true });
  if (!yes) return;
  try {
    const res = await fetch('/newAdmin/deleteEntry', {
      method: 'delete',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id })
    });
    const data = await res.json();
    if (data !== 'success') throw new Error();
    toast('Couple deleted.');
    await refreshData();
  } catch (e) {
    toast('Could not delete the couple.', 'err');
  }
}

/* ================= verify / collecting toggle ================= */
async function toggleCollecting(id, checkbox) {
  const c = state.couples.find(x => String(x._id) === String(id));
  if (!c) return;
  const turningOn = checkbox.checked;

  const yes = await askConfirm(turningOn
    ? 'Start collecting for <b>' + esc(c.chossonName) + ' &amp; ' + esc(c.kallahName) + '</b>? This verifies the couple and features them as the newest couple.'
    : 'Stop collecting for <b>' + esc(c.chossonName) + ' &amp; ' + esc(c.kallahName) + '</b>?',
    { title: turningOn ? 'Start collecting' : 'Stop collecting', yesText: turningOn ? 'Start' : 'Stop' });
  if (!yes) { checkbox.checked = !turningOn; return; }

  try {
    const res = await fetch('/newAdmin/verifyEntry', {
      method: 'put',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id })
    });
    const data = await res.json();
    if (data === 'error') throw new Error();

    if (data === 'verified') {
      toast('Couple verified & collecting.', 'gold');
      await refreshData();
      const sendIt = await askConfirm(
        'Send the collection email announcing <b>' + esc(c.chossonName) + ' &amp; ' + esc(c.kallahName) + '</b> to all subscribers now?',
        { title: 'Send announcement?', yesText: 'Send Email', noText: 'Not now' });
      if (sendIt) await doSend('/newAdmin/sendNewsletter', { id });
    } else {
      toast('Collecting stopped.');
      await refreshData();
    }
  } catch (e) {
    checkbox.checked = !turningOn;
    toast('Something went wrong — nothing was changed.', 'err');
  }
}

/* ================= send emails ================= */
async function sendCollectionEmail() {
  const collecting = state.couples.filter(c => c.collecting).length;
  if (!collecting && !state.newCouple.length) {
    toast('No couples are collecting right now.', 'err');
    return;
  }
  const yes = await askConfirm(
    'Send the collection email to <b>all subscribers</b>?' +
    (state.newCouple.length ? '<br><br>Featuring: <b>' + esc(state.newCouple[0].chosson) + ' &amp; ' + esc(state.newCouple[0].kallah) + '</b>' : '') +
    '<br>Including ' + collecting + ' collecting couple' + (collecting === 1 ? '' : 's') + '.',
    { title: 'Send collection email', yesText: 'Send' });
  if (!yes) return;
  await doSend('/newAdmin/sendNewNewsletter', null);
}

async function doSend(url, body) {
  $('sendingOverlay').classList.add('show');
  try {
    const res = await fetch(url, {
      method: 'post',
      headers: { 'Content-Type': 'application/json' },
      body: body ? JSON.stringify(body) : undefined
    });
    const data = await res.json();
    if (data !== 'success') throw new Error();
    toast('Email sent to all subscribers! 🎉', 'gold');
    await refreshData();
  } catch (e) {
    toast('The email could not be sent. Check the server logs.', 'err');
  } finally {
    $('sendingOverlay').classList.remove('show');
  }
}

/* ================= wiring ================= */
$('searchInput').addEventListener('input', (e) => { searchTerm = e.target.value; renderTable(); });
$('filterChips').addEventListener('click', (e) => {
  const chip = e.target.closest('.chip');
  if (!chip) return;
  activeFilter = chip.dataset.filter;
  document.querySelectorAll('.chip').forEach(c => c.classList.toggle('active', c === chip));
  renderTable();
});
document.querySelectorAll('.overlay').forEach(ov => {
  ov.addEventListener('mousedown', (e) => {
    if (e.target === ov) {
      if (ov.id === 'confirmOverlay') resolveConfirm(false);
      else ov.classList.remove('show');
    }
  });
});
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    if ($('confirmOverlay').classList.contains('show')) resolveConfirm(false);
    else document.querySelectorAll('.overlay.show').forEach(ov => ov.classList.remove('show'));
  }
});

$('todayDate').textContent = new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
renderAll();
</script>
</body>
</html>
